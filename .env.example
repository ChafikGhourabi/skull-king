# .env.example
# Copy to .env.local and fill in values from your Supabase project dashboard
# Never commit .env.local — it is gitignored (*.local matches .env.local)

# Supabase — Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx

# Google OAuth secret — only needed for local Supabase CLI; not used in Netlify
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=
